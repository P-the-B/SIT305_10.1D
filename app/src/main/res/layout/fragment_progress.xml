<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header row with sort button and mode label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="0dp"
        android:gravity="center_vertical">

        <!-- Title and subtitle stacked -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Learning Progress"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <!-- Hint so users know the cards are tappable -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Tap a topic for more details."
                android:textSize="14sp"
                android:textColor="@color/text_hint"/>

        </LinearLayout>

        <!-- Current sort mode label -->
        <TextView
            android:id="@+id/tvSortLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:text="A–Z"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"/>

        <!-- Sort toggle button -->
        <ImageButton
            android:id="@+id/btnSort"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_sort"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Sort topics"/>

    </LinearLayout>

    <!-- Empty state — shown when no attempts yet -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="80dp"
        android:text="Complete a quiz to see your progress here"
        android:textSize="15sp"
        android:textColor="@color/text_hint"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

    <!-- Topic progress list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:paddingTop="4dp">

        <LinearLayout
            android:id="@+id/containerProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </ScrollView>

</LinearLayout>