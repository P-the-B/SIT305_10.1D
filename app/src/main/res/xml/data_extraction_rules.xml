<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- DB contains password hashes — must not reach Google cloud -->
        <exclude domain="database" path="mylearning.db" />
        <!-- Session prefs contain userId + tier — restoring to another device grants access -->
        <exclude domain="sharedpref" path="mylearning_session.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="mylearning.db" />
        <exclude domain="sharedpref" path="mylearning_session.xml" />
    </device-transfer>
</data-extraction-rules>